DJANGO_DEBUG=True
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://footbook.online,
    https://www.footbook.online,

# Leave DB_HOST blank for local SQLite. Set these in Azure App Service for PostgreSQL.
DB_HOST=
