DJANGO_DEBUG=True
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=127.0.0.1,localhost,footbook.online,www.footbook.online
FOOTBOOK_DEMO_MODE=False
CSRF_TRUSTED_ORIGINS="http://127.0.0.1:8000,http://localhost:8000,https://footbook.online,https://www.footbook.online"
SESSION_COOKIE_DOMAIN=.footbook.online
CSRF_COOKIE_DOMAIN=.footbook.online

# Leave DB_HOST blank for local SQLite. Set these in Azure App Service for PostgreSQL.
DB_HOST=
DB_NAME=footbook
DB_USER=footbookadmin
DB_PASSWORD=
DB_PORT=5432
DB_SSLMODE=require
DB_CONN_MAX_AGE=60

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST_USER=foo.book.online.india@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_SENDER_NAME=FootBook
EMAIL_SENDER_ADDRESS=foo.book.online.india@gmail.com
EMAIL_SUBJECT_PREFIX="[FootBook] "
DEFAULT_FROM_EMAIL="FootBook <foo.book.online.india@gmail.com>"
SERVER_EMAIL="FootBook <foo.book.online.india@gmail.com>"
PREGENERATE_FUTURE_SLOTS=False

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

STRIPE_SECRET_KEY=
